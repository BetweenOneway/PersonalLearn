<%- include('partials/header', { title }) %>

<div class="page-header">
  <h1>ℹ️ <%= title %></h1>
  <p>关于本模板引擎示例的技术栈与说明</p>
</div>

<!-- ===== 技术栈 ===== -->
<div class="card">
  <h2 style="margin-bottom:1rem;">🛠 技术栈</h2>
  <% techStack.forEach(function(tech) { %>
    <div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 0;border-bottom:1px solid #f0f0f0;">
      <div>
        <strong><%= tech.name %></strong>
        <span style="color:#888;margin-left:0.75rem;font-size:0.85rem;"><%= tech.version %></span>
      </div>
      <a href="<%= tech.url %>" target="_blank" style="color:#4a90d9;text-decoration:none;font-size:0.9rem;">文档 ↗</a>
    </div>
  <% }); %>
</div>

<!-- ===== 项目结构 ===== -->
<div class="card">
  <h2 style="margin-bottom:1rem;">📁 项目结构</h2>
  <pre style="background:#1a1a2e;color:#0f0;padding:1rem;border-radius:8px;overflow-x:auto;font-size:0.9rem;line-height:1.8;">TemplateEngine/
├── package.json        ← 项目配置与依赖
├── server.js           ← Express 服务器 + 路由
└── views/              ← EJS 模板目录
    ├── partials/
    │   ├── header.ejs  ← 公共头部（导航栏）
    │   └── footer.ejs  ← 公共页脚
    ├── index.ejs       ← 首页
    ├── users.ejs       ← 用户列表
    ├── articles.ejs    ← 文章列表
    ├── form.ejs        ← 注册表单
    ├── form-success.ejs← 注册成功
    └── about.ejs       ← 关于页面</pre>
</div>

<!-- ===== 关键代码展示 ===== -->
<div class="card">
  <h2 style="margin-bottom:1rem;">🔧 服务端关键代码</h2>
  <pre style="background:#1a1a2e;color:#e0e0e0;padding:1rem;border-radius:8px;overflow-x:auto;font-size:0.85rem;line-height:1.7;"><span style="color:#569cd6;">const</span> express = <span style="color:#dcdcaa;">require</span>(<span style="color:#ce9178;">'express'</span>);
<span style="color:#569cd6;">const</span> app = <span style="color:#dcdcaa;">express</span>();

<span style="color:#6a9955;">// 1. 设置模板引擎</span>
app.<span style="color:#dcdcaa;">set</span>(<span style="color:#ce9178;">'view engine'</span>, <span style="color:#ce9178;">'ejs'</span>);

<span style="color:#6a9955;">// 2. 渲染模板并传递数据</span>
app.<span style="color:#dcdcaa;">get</span>(<span style="color:#ce9178;">'/'</span>, (req, res) => {
  res.<span style="color:#dcdcaa;">render</span>(<span style="color:#ce9178;">'index'</span>, {
    title: <span style="color:#ce9178;">'首页'</span>,
    users: [...],
    <span style="color:#6a9955;">// ... 任意数据</span>
  });
});</pre>
</div>

<%- include('partials/footer') %>
