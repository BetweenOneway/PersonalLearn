{
    "name": "Client — Vue 3 + Vite 前端",

    // ==================== 核心：dockerComposeFile 模式 ====================
    // 指向 client 目录下的 docker-compose.yml
    "dockerComposeFile": "docker-compose.yml",

    // VSCode 连接到 client 容器进行前端开发
    "service": "client",

    // 容器内工作目录
    "workspaceFolder": "/app",

    // ==================== VSCode 定制 ====================
    "customizations": {
        "vscode": {
            "extensions": [
                "Vue.volar",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "ms-azuretools.vscode-docker"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "editor.rulers": [120],
                "files.insertFinalNewline": true,
                "terminal.integrated.defaultProfile.linux": "bash",
                "javascript.preferences.importModuleSpecifier": "relative"
            }
        }
    },

    // ==================== 端口转发 ====================
    // Vite 开发服务器运行在 5173 端口
    "forwardPorts": [5173],

    "portsAttributes": {
        "5173": {
            "label": "Vue Dev Server (Vite)",
            "onAutoForward": "notify"
        }
    },

    // ==================== 生命周期钩子 ====================
    "postCreateCommand": "cd /app && npm install",

    "postStartCommand": "echo '✅ Client DevContainer 就绪！' && echo '🌐 前端: http://localhost:5173' && echo '📡 API 代理到 server:3000' && echo '🚀 npm run dev 启动 Vite 开发服务器（支持 HMR）'",

    // ==================== 其他配置 ====================
    "remoteUser": "root",
    "shutdownAction": "stopCompose",
    "overrideCommand": false
}
