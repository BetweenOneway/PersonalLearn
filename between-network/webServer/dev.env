# ============================================
# 环境变量（开发环境）
# ============================================

# MySQL（root 仅用于容器初始化和健康检查）
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=cloudnote
MYSQL_HOST=mysql

# MySQL 业务用户（仅 CRUD 权限，应用代码使用此用户）
DB_USER=cloudnote
DB_PASSWORD=cloudnote123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Server
NODE_ENV=development
SERVER_PORT=18081
