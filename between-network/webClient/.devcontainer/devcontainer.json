{
    "name": "between-network-web-client",

    // ==================== 核心：dockerComposeFile 模式 ====================
    // 指向 webClient 目录下的 docker-compose.yml
    "dockerComposeFile": "../docker-compose.yml",

    // VSCode 连接到 client 容器进行前端开发
    "service": "client",

    // 容器内工作目录
    "workspaceFolder": "/app",

    // ==================== VSCode 定制 ====================
    "customizations": {
        "vscode": {
            "extensions": [
                "Vue.volar",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "ms-azuretools.vscode-docker",
                "bradlc.vscode-tailwindcss"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "editor.rulers": [120],
                "files.insertFinalNewline": true,
                "terminal.integrated.defaultProfile.linux": "bash",
                "javascript.preferences.importModuleSpecifier": "relative"
            }
        }
    },

    // ==================== 端口转发 ====================
    "forwardPorts": [18080],

    "portsAttributes": {
        "18080": {
            "label": "webClient Dev Server",
            "onAutoForward": "notify"
        }
    },

    // ==================== 生命周期钩子 ====================
    "postCreateCommand": "cd /app && npm install",

    "postStartCommand": "echo '✅ webClient DevContainer 就绪！' && echo '  Vite Dev Server 端口: 18080' && echo '🚀 npm run dev 启动前端服务' && echo '🌐 http://localhost:18080'",

    // ==================== 其他配置 ====================
    "remoteUser": "root",
    "shutdownAction": "stopCompose",
    "overrideCommand": false
}
